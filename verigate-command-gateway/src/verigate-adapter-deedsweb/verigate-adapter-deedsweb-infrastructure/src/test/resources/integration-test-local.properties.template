# DeedsWeb Live Integration Test - Local Configuration
# Copy this file to integration-test-local.properties and fill in real values.
# integration-test-local.properties is gitignored - never commit real credentials!

# REQUIRED: SOAP credentials issued by the Deeds Office.
deedsweb.username=PASTE_YOUR_USERNAME_HERE
deedsweb.password=PASTE_YOUR_PASSWORD_HERE

# OPTIONAL: Override the SOAP endpoint (defaults to the production registry).
# deedsweb.base.url=http://deedssoap.deeds.gov.za:80/deeds-registration-soap/

# REQUIRED: Enable the gated live tests.
integration.test.enabled=true
