# VeriGate Partner Portal — Environment Variables
# Copy to .env.local and fill in values

# BFF URL (browser-accessible, used by client-side code)
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:8080

# API key for BFF authentication (embedded in static build)
NEXT_PUBLIC_API_KEY=

# Mock mode — set to "false" to call real BFF
NEXT_PUBLIC_USE_MOCK=true

# Authentication — set to "false" to enable session checks
NEXT_PUBLIC_AUTH_DISABLED=true

# Partner identity
NEXT_PUBLIC_PARTNER_ID=partner-portal

# Environment label (shown in UI)
NEXT_PUBLIC_ENV=development
