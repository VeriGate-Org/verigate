# Client-side (browser) — routes through Next.js API proxy at /api/bff/*
NEXT_PUBLIC_BFF_BASE_URL=/api/bff
NEXT_PUBLIC_API_KEY=vg_live_localdev0000000000000000000000000000000000000000000000000000
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_AUTH_DISABLED=true
NEXT_PUBLIC_PARTNER_ID=partner-acme
NEXT_PUBLIC_ENV=local

# Server-side — used by Next.js API proxy routes to reach the BFF
BFF_BASE_URL=http://localhost:8080
BFF_API_KEY=vg_live_localdev0000000000000000000000000000000000000000000000000000
