# VeriGate Website - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# EMAIL SERVICE CONFIGURATION
# =============================================================================
# Choose your email provider: SendGrid, AWS SES, Mailgun, etc.
# Get API key from your email service provider

VITE_EMAIL_API_KEY=your_email_api_key_here
VITE_FROM_EMAIL=noreply@verigate.com
VITE_FROM_NAME=VeriGate
VITE_SALES_EMAIL=sales@verigate.com

# =============================================================================
# CRM INTEGRATION
# =============================================================================
# Choose your CRM: 'hubspot', 'salesforce', or 'custom'
VITE_CRM_PLATFORM=custom

# --- HubSpot Configuration (if using HubSpot) ---
# Get these from: https://app.hubspot.com/settings
VITE_HUBSPOT_API_KEY=your_hubspot_api_key
VITE_HUBSPOT_PORTAL_ID=your_portal_id
VITE_HUBSPOT_CONTACT_FORM_ID=your_contact_form_id
VITE_HUBSPOT_DEMO_FORM_ID=your_demo_form_id

# --- Salesforce Configuration (if using Salesforce) ---
# Get these from your Salesforce setup
VITE_SALESFORCE_ORG_ID=your_org_id
VITE_SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
VITE_SALESFORCE_ACCESS_TOKEN=your_access_token

# =============================================================================
# ANALYTICS & TRACKING
# =============================================================================

# --- Google Analytics 4 ---
# Get from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Microsoft Clarity ---
# Get from: https://clarity.microsoft.com/
# Free heatmaps and session recordings
VITE_CLARITY_PROJECT_ID=your_clarity_project_id

# --- Facebook Pixel (optional for marketing) ---
# Get from: https://business.facebook.com/events_manager
VITE_FB_PIXEL_ID=your_facebook_pixel_id

# --- LinkedIn Insight Tag (optional for B2B marketing) ---
# Get from: https://www.linkedin.com/campaign-manager
VITE_LINKEDIN_PARTNER_ID=your_linkedin_partner_id
VITE_LINKEDIN_DEMO_CONVERSION_ID=your_demo_conversion_id
VITE_LINKEDIN_SIGNUP_CONVERSION_ID=your_signup_conversion_id

# --- Twitter/X Pixel (optional) ---
VITE_TWITTER_PIXEL_ID=your_twitter_pixel_id

# =============================================================================
# LIVE CHAT INTEGRATION
# =============================================================================
# Choose your chat provider: 'tawk', 'intercom', 'crisp', or 'custom'
VITE_CHAT_PROVIDER=custom

# --- Tawk.to (FREE) ---
# Get from: https://tawk.to/
VITE_TAWK_PROPERTY_ID=your_property_id
VITE_TAWK_WIDGET_ID=your_widget_id

# --- Intercom (PAID - $74+/month) ---
# Get from: https://app.intercom.com/
VITE_INTERCOM_APP_ID=your_intercom_app_id

# --- Crisp (FREE tier available) ---
# Get from: https://crisp.chat/
VITE_CRISP_WEBSITE_ID=your_crisp_website_id

# =============================================================================
# THIRD-PARTY SERVICES (Optional)
# =============================================================================

# --- reCAPTCHA (for spam protection) ---
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# --- Stripe (for payment/subscriptions - future) ---
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# --- Sentry (for error tracking - recommended) ---
# Get from: https://sentry.io/
VITE_SENTRY_DSN=your_sentry_dsn

# --- PostHog (for product analytics - optional) ---
VITE_POSTHOG_KEY=your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
VITE_ENV=development

# API Base URL (if you have a backend API)
VITE_API_URL=https://api.verigate.com

# Feature Flags
VITE_FEATURE_CHAT=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_AB_TESTING=false

# =============================================================================
# NOTES
# =============================================================================
# 
# Quick Start Guide:
# 
# 1. FREE TIER SETUP (No cost):
#    - Use 'custom' for CRM_PLATFORM (logs to console)
#    - Use 'custom' for CHAT_PROVIDER (built-in widget)
#    - Add GA_MEASUREMENT_ID (free Google Analytics)
#    - Add CLARITY_PROJECT_ID (free Microsoft Clarity)
#    - Skip all paid services
# 
# 2. BUDGET SETUP ($0-50/month):
#    - Add Tawk.to for live chat (free)
#    - Add HubSpot free tier for CRM
#    - Add Google Analytics + Clarity
#    - Add email service (SendGrid free tier: 100 emails/day)
# 
# 3. PROFESSIONAL SETUP ($150-500/month):
#    - HubSpot Starter ($45/month)
#    - Intercom ($74/month)
#    - SendGrid Essentials ($15/month)
#    - LinkedIn Ads + Facebook Pixel
#    - Sentry for error tracking
# 
# 4. ENTERPRISE SETUP ($500+/month):
#    - HubSpot Professional
#    - Intercom or Drift
#    - SendGrid Pro or AWS SES
#    - All marketing pixels
#    - Advanced analytics + A/B testing
# 
# Security Best Practices:
# - Never commit .env.local to version control
# - Rotate API keys regularly
# - Use different keys for dev/staging/production
# - Restrict API keys to specific domains in production
# - Enable 2FA on all service accounts
# 
# =============================================================================
