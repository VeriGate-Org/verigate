# VeriGate Billing Service Environment Configuration
# Copy this file to .env and fill in the values for local development

# ===========================
# AWS Configuration
# ===========================

# AWS region where resources are deployed
AWS_REGION=eu-west-1

# ===========================
# DynamoDB Tables
# ===========================

# Usage records table name (tracks individual verification events)
USAGE_RECORDS_TABLE_NAME=verigate-usage-records

# Usage summaries table name (aggregated usage data)
USAGE_SUMMARIES_TABLE_NAME=verigate-usage-summaries

# Billing plans table name (partner billing configuration)
BILLING_PLANS_TABLE_NAME=verigate-billing-plans

# ===========================
# Kinesis Stream
# ===========================

# Kinesis stream name for verification events
EVENT_STREAM_NAME=verigate-verification-events

# Batch size for Kinesis event processing
# KINESIS_BATCH_SIZE=100

# ===========================
# Aggregation Configuration
# ===========================

# Batch size for usage aggregation
# AGGREGATION_BATCH_SIZE=100

# Maximum page size for DynamoDB queries during aggregation
# AGGREGATION_MAX_QUERY_PAGE_SIZE=1000

# ===========================
# Billing Defaults
# ===========================

# Monthly minimum charge (in currency units)
# BILLING_MONTHLY_MINIMUM=500.00

# Price per verification (in currency units)
# BILLING_PRICE_PER_VERIFICATION=2.50

# ===========================
# Logging Configuration
# ===========================

# Logging level (INFO, DEBUG, WARN, ERROR)
# BILLING_LOGGING_LEVEL=INFO

# Enable debug logging
# BILLING_LOGGING_ENABLE_DEBUG=false
