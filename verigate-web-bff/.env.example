# VeriGate Web BFF — Environment Variables
# Copy to .env.local and fill in values for your environment
#
# This Spring Boot application provides a backend-for-frontend (BFF) layer
# for the VeriGate verification platform, handling HTTP requests and routing
# commands to the verification gateway via SQS queues.

# =============================================================================
# AWS CONFIGURATION
# =============================================================================

# AWS region for all AWS services (SQS, DynamoDB, Cognito)
# Default: eu-west-1
AWS_REGION=eu-west-1

# AWS SQS endpoint override (for LocalStack or custom endpoints)
# Leave empty for production AWS endpoints
# Example for LocalStack: http://localhost:4566
AWS_SQS_ENDPOINT=

# AWS DynamoDB endpoint override (for LocalStack or custom endpoints)
# Leave empty for production AWS endpoints
# Example for LocalStack: http://localhost:4566
AWS_DYNAMODB_ENDPOINT=

# =============================================================================
# AUTHENTICATION & AUTHORIZATION
# =============================================================================

# Enable/disable AWS Cognito JWT authentication
# Set to "true" in production, "false" for local development
# Default: false
VERIGATE_COGNITO_ENABLED=false

# AWS Cognito User Pool ID
# Get from: AWS Console > Cognito > User Pools
# Example: af-south-1_ABC123XYZ
VERIGATE_COGNITO_USER_POOL_ID=

# AWS Cognito region (may differ from AWS_REGION)
# Default: af-south-1
VERIGATE_COGNITO_REGION=af-south-1

# AWS Cognito App Client ID
# Get from: AWS Console > Cognito > User Pools > App Integration
VERIGATE_COGNITO_APP_CLIENT_ID=

# DynamoDB table name for API key storage and validation
# Default: verigate-api-keys
VERIGATE_API_KEYS_TABLE=verigate-api-keys

# =============================================================================
# RATE LIMITING
# =============================================================================

# Enable/disable rate limiting for API requests
# Default: true
VERIGATE_RATE_LIMIT_ENABLED=true

# Default number of requests allowed per minute per partner
# Default: 100
VERIGATE_RATE_LIMIT_DEFAULT=100

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================

# SQS queue name for partner creation commands
# Default: partner-create
VERIGATE_PARTNER_CREATE_QUEUE_NAME=partner-create

# SQS queue name for verification requests
# Default: verify-party
VERIGATE_VERIFICATION_QUEUE_NAME=verify-party

# =============================================================================
# COMMAND STORE CONFIGURATION
# =============================================================================

# DynamoDB table name for verification command status tracking
# Default: verification-command-store
VERIGATE_COMMAND_STORE_TABLE=verification-command-store

# =============================================================================
# RESPONSE POLLING CONFIGURATION
# =============================================================================

# Timeout in milliseconds between polling attempts for command responses
# Lower values = more frequent polling, higher AWS costs
# Default: 50
VERIGATE_RESPONSE_POLL_TIMEOUT_MS=50

# Maximum number of polling attempts before returning in-progress status
# Default: 1
VERIGATE_RESPONSE_POLL_MAX_ATTEMPTS=1

# =============================================================================
# QUICK START GUIDE
# =============================================================================
#
# Local Development (with LocalStack):
#   1. Start LocalStack: docker run -d -p 4566:4566 localstack/localstack
#   2. Set AWS endpoints to http://localhost:4566
#   3. Set VERIGATE_COGNITO_ENABLED=false
#   4. Use default queue and table names
#   5. Run: mvn spring-boot:run
#
# Production:
#   1. Set AWS_REGION to your deployment region
#   2. Leave AWS endpoint overrides empty
#   3. Set VERIGATE_COGNITO_ENABLED=true
#   4. Configure all Cognito variables
#   5. Set production queue and table names
#   6. Adjust rate limits for expected traffic
#
# Security Notes:
#   - Never commit .env.local to version control
#   - Use IAM roles for AWS credentials in production
#   - Rotate API keys regularly
#   - Enable rate limiting in production
#   - Use separate configurations for dev/staging/production
#
# =============================================================================
