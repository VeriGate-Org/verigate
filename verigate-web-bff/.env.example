# VeriGate Web-BFF Environment Configuration
# Copy this file to .env and fill in the values for local development

# ===========================
# AWS Configuration
# ===========================

# AWS region where resources are deployed
AWS_REGION=eu-west-1

# Optional: Override SQS endpoint for local development (LocalStack)
# AWS_SQS_ENDPOINT=http://localhost:4566

# Optional: Override DynamoDB endpoint for local development (LocalStack)
# AWS_DYNAMODB_ENDPOINT=http://localhost:4566

# ===========================
# Authentication - Cognito
# ===========================

# Enable/disable Cognito authentication
VERIGATE_COGNITO_ENABLED=false

# AWS Cognito User Pool ID
# VERIGATE_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX

# AWS Cognito region
VERIGATE_COGNITO_REGION=af-south-1

# AWS Cognito App Client ID
# VERIGATE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================
# Rate Limiting
# ===========================

# Enable/disable API rate limiting
VERIGATE_RATE_LIMIT_ENABLED=true

# Default requests per minute per API key
VERIGATE_RATE_LIMIT_DEFAULT=100

# ===========================
# DynamoDB Tables
# ===========================

# API keys table name
VERIGATE_API_KEYS_TABLE=verigate-api-keys

# Verification command store table name
VERIGATE_COMMAND_STORE_TABLE=verification-command-store

# ===========================
# SQS Queues
# ===========================

# Partner creation queue name
VERIGATE_PARTNER_CREATE_QUEUE_NAME=partner-create

# Verification queue name (for verify party commands)
VERIGATE_VERIFICATION_QUEUE_NAME=verify-party

# ===========================
# Response Polling Configuration
# ===========================

# Timeout in milliseconds for polling verification responses
VERIGATE_RESPONSE_POLL_TIMEOUT_MS=50

# Maximum number of polling attempts for verification responses
VERIGATE_RESPONSE_POLL_MAX_ATTEMPTS=1
