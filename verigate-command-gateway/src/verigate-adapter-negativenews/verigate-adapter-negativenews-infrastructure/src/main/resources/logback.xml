<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{ISO8601} [%thread] %-5level %logger{36} - [partnerId=%X{partnerId}] [verificationId=%X{verificationId}] [commandId=%X{commandId}] [correlationId=%X{correlationId}] %msg%n</pattern>
    </encoder>
  </appender>
  <logger name="verigate" level="DEBUG"/>
  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
