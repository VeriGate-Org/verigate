# VeriGate Risk Engine — Environment Variables
# These are configured as Lambda environment variables in SAM template

# --- DynamoDB Tables ---
RISK_SCORING_CONFIG_TABLE_NAME=verigate-risk-engine-risk-scoring-config
RISK_ASSESSMENTS_TABLE_NAME=verigate-risk-engine-risk-assessments
VERIFICATION_WORKFLOWS_TABLE_NAME=verigate-risk-engine-verification-workflows

# --- AWS ---
AWS_REGION=eu-west-1

# --- Kinesis (Event Source) ---
# The Kinesis stream ARN is resolved from SSM in the SAM template:
# /verigate-verification-cg/events/kinesis/stream-arn

# --- Datadog (Observability) ---
DD_ENV=sds-dev
DD_SERVICE=verigate-risk-engine
DD_VERSION=latest
